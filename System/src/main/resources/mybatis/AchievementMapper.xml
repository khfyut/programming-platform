<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.programming.mapper.AchievementMapper">
    <select id="findById" resultType="com.programming.entity.Achievement">
        SELECT * FROM achievement WHERE id = #{id}
    </select>

    <select id="findByConditionType" resultType="com.programming.entity.Achievement">
        SELECT * FROM achievement WHERE condition_type = #{conditionType}
    </select>

    <select id="findByUserId" resultType="com.programming.entity.UserAchievement">
        SELECT * FROM user_achievement WHERE user_id = #{userId}
    </select>

    <select id="hasUserAchievement" resultType="java.lang.Boolean">
        SELECT EXISTS(
            SELECT 1 FROM user_achievement
            WHERE user_id = #{userId} AND achievement_id = #{achievementId}
        )
    </select>

    <insert id="insertUserAchievement" parameterType="com.programming.entity.UserAchievement">
        INSERT INTO user_achievement (user_id, achievement_id, create_time)
        VALUES (#{userId}, #{achievementId}, #{createTime})
    </insert>
</mapper>