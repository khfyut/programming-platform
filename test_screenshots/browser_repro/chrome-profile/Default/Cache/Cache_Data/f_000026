  newPost.value = {
    type: 'discussion',
    title: '',
    content: ''
  }
  createDialogVisible.value = true
}

const handleCreatePost = async () => {
  if (!newPost.value.title.trim()) {
    ElMessage.warning('请输入标题')
    return
  }

  if (!newPost.value.content.trim()) {
    ElMessage.warning('请输入内容')
    return
  }

