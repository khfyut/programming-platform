<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.programming.mapper.SubmitMapper">

    <resultMap id="BaseResultMap" type="com.programming.entity.Submit">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="problem_id" property="problemId"/>
        <result column="code" property="code"/>
        <result column="language" property="language"/>
        <result column="result" property="result"/>
        <result column="time_cost" property="timeCost"/>
        <result column="memory_cost" property="memoryCost"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.programming.entity.Submit" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO submit (user_id, problem_id, code, language, result, time_cost, memory_cost)
        VALUES (#{userId}, #{problemId}, #{code}, #{language}, #{result}, #{timeCost}, #{memoryCost})
    </insert>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM submit
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="problemId != null">
                AND problem_id = #{problemId}
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{size} OFFSET #{page}
    </select>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM submit
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="problemId != null">
                AND problem_id = #{problemId}
            </if>
        </where>
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM submit ORDER BY id DESC LIMIT #{size} OFFSET #{page}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM submit
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM submit WHERE id = #{id}
    </select>

</mapper>
