<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.programming.mapper.QuestionMapper">

    <resultMap id="BaseResultMap" type="com.programming.entity.Question">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="answer" property="answer"/>
        <result column="code" property="code"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.programming.entity.Question">
        INSERT INTO question (user_id, content, answer, code, create_time)
        VALUES (#{userId}, #{content}, #{answer}, #{code}, NOW())
    </insert>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM question WHERE user_id = #{userId}
        ORDER BY id DESC
        LIMIT #{size} OFFSET #{page}
    </select>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM question WHERE user_id = #{userId}
    </select>
</mapper>
