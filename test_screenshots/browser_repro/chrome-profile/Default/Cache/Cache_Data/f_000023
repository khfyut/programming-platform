      if (statusDiff !== 0) return statusDiff
      return new Date(b.createTime || 0).getTime() - new Date(a.createTime || 0).getTime()
    })
  } else {
    list.sort((a, b) => new Date(b.createTime || 0).getTime() - new Date(a.createTime || 0).getTime())
  }

  return list
