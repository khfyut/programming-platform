<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.programming.mapper.AiSessionMapper">

    <resultMap id="SessionResultMap" type="com.programming.entity.AiSession">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="user_id" property="userId"/>
        <result column="topic" property="topic"/>
        <result column="status" property="status"/>
        <result column="session_type" property="sessionType"/>
        <result column="related_problem_id" property="relatedProblemId"/>
        <result column="related_wrong_item_id" property="relatedWrongItemId"/>
        <result column="last_submit_id" property="lastSubmitId"/>
        <result column="metadata_json" property="metadataJson"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="MessageResultMap" type="com.programming.entity.AiMessage">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="related_problem_id" property="relatedProblemId"/>
        <result column="related_submit_id" property="relatedSubmitId"/>
        <result column="message_kind" property="messageKind"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="CollectionResultMap" type="com.programming.entity.AiCollection">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="session_id" property="sessionId"/>
        <result column="message_id" property="messageId"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectSessionById" resultMap="SessionResultMap">
        SELECT * FROM ai_session WHERE id = #{id}
    </select>

    <select id="selectSessionBySessionId" resultMap="SessionResultMap">
        SELECT * FROM ai_session WHERE session_id = #{sessionId}
    </select>

    <select id="selectSessionsByUserId" resultMap="SessionResultMap">
        SELECT * FROM ai_session 
        WHERE user_id = #{userId} 
          AND (session_type IS NULL OR session_type = 'general')
        ORDER BY update_time DESC
    </select>

    <select id="selectLatestProblemCoachSession" resultMap="SessionResultMap">
        SELECT * FROM ai_session
        WHERE user_id = #{userId}
          AND session_type = 'problem_coach'
          AND related_problem_id = #{problemId}
        ORDER BY update_time DESC, id DESC
        LIMIT 1
    </select>

    <select id="selectLatestWrongBookReviewSession" resultMap="SessionResultMap">
        SELECT * FROM ai_session
        WHERE user_id = #{userId}
          AND session_type = 'wrong_book_review'
          AND related_wrong_item_id = #{wrongItemId}
        ORDER BY update_time DESC, id DESC
        LIMIT 1
    </select>

    <insert id="insertSession" parameterType="com.programming.entity.AiSession" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_session (
            session_id,
            user_id,
            topic,
            status,
            session_type,
            related_problem_id,
            related_wrong_item_id,
            last_submit_id,
            metadata_json,
            create_time,
            update_time
        )
        VALUES (
            #{sessionId},
            #{userId},
            #{topic},
            #{status},
            #{sessionType},
            #{relatedProblemId},
            #{relatedWrongItemId},
            #{lastSubmitId},
            #{metadataJson},
            NOW(),
            NOW()
        )
    </insert>

    <update id="updateSession" parameterType="com.programming.entity.AiSession">
        UPDATE ai_session 
        SET topic = #{topic},
            status = #{status},
            session_type = #{sessionType},
            related_problem_id = #{relatedProblemId},
            related_wrong_item_id = #{relatedWrongItemId},
            last_submit_id = #{lastSubmitId},
            metadata_json = #{metadataJson},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteSession" parameterType="java.lang.Long">
        DELETE FROM ai_session WHERE id = #{id}
    </delete>

    <select id="selectMessagesBySessionId" resultMap="MessageResultMap">
        SELECT * FROM ai_message 
        WHERE session_id = #{sessionId} 
        ORDER BY create_time ASC
    </select>

    <insert id="insertMessage" parameterType="com.programming.entity.AiMessage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_message (
            session_id,
            role,
            content,
            related_problem_id,
            related_submit_id,
            message_kind,
            create_time
        )
        VALUES (
            #{sessionId},
            #{role},
            #{content},
            #{relatedProblemId},
            #{relatedSubmitId},
            #{messageKind},
            NOW()
        )
    </insert>

    <delete id="deleteMessagesBySessionId" parameterType="java.lang.String">
        DELETE FROM ai_message WHERE session_id = #{sessionId}
    </delete>

    <select id="selectCollectionsByUserId" resultMap="CollectionResultMap">
        SELECT * FROM ai_collection 
        WHERE user_id = #{userId} 
        ORDER BY create_time DESC
    </select>

    <select id="selectCollectionById" resultMap="CollectionResultMap">
        SELECT * FROM ai_collection WHERE id = #{id}
    </select>

    <insert id="insertCollection" parameterType="com.programming.entity.AiCollection" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_collection (user_id, session_id, message_id, content, create_time)
        VALUES (#{userId}, #{sessionId}, #{messageId}, #{content}, NOW())
    </insert>

    <delete id="deleteCollection" parameterType="java.lang.Long">
        DELETE FROM ai_collection WHERE id = #{id}
    </delete>

</mapper>
