<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.programming.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.programming.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="role" property="role"/>
        <result column="language" property="language"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <insert id="insert" parameterType="com.programming.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, role, language)
        VALUES (#{username}, #{password}, #{role}, #{language})
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <update id="updateLanguage">
        UPDATE user SET language = #{language} WHERE id = #{id}
    </update>

    <select id="findByPage" resultMap="BaseResultMap">
        SELECT * FROM user ORDER BY id DESC LIMIT #{size} OFFSET #{page}
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM user
    </select>

</mapper>
