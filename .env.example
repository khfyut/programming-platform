# Backend runtime
SERVER_PORT=8080

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=programming_system
DB_USER=root
DB_PASSWORD=123456

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Application
PROGRAMMING_JWT_SECRET=change_this_to_a_secure_secret
PROGRAMMING_JWT_EXPIRE=86400000

# Docker sandbox host (for code run/judge)
PROGRAMMING_DOCKER_HOST=tcp://127.0.0.1:2375
PROGRAMMING_DOCKER_TIMEOUT=2000
PROGRAMMING_DOCKER_MEMORY=134217728

# AI
PROGRAMMING_AI_API_KEY=
PROGRAMMING_AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PROGRAMMING_AI_PROMPT=你是专业的编程助教，只回答编程相关问题，给出清晰思路和示例代码，不直接给完整答案。
